{
  "name": "agentix-cli",
  "version": "0.13.0",
  "description": "Self-hosted multi-agent orchestrator — routes Telegram, WhatsApp, crons, and A2A mesh tasks to Claude Code, OpenAI, or any LLM provider",
  "license": "MIT",
  "author": {
    "name": "anis_marrouchi",
    "url": "https://twitter.com/anis_marrouchi"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/anis-marrouchi/agentx.git"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "bin": {
    "agentx": "./dist/cli.js"
  },
  "files": [
    "dist",
    "agentx.example.json"
  ],
  "keywords": [
    "ai",
    "agent",
    "multi-agent",
    "orchestrator",
    "claude-code",
    "claude",
    "telegram",
    "whatsapp",
    "cron",
    "a2a",
    "mesh",
    "swarm",
    "mcp",
    "self-hosted",
    "bring-your-own-key"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "clean": "rimraf dist",
    "format:write": "prettier --write \"src/**/*.{ts,tsx,mdx}\" --cache",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,mdx}\" --cache",
    "eval": "vitest run test/eval/",
    "eval:track": "TRACK_SCORES=1 vitest run test/eval/real-data-eval.test.ts",
    "usage:track": "tsx src/scripts/track-usage.ts",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@whiskeysockets/baileys": "7.0.0-rc.9",
    "chalk": "5.2.0",
    "commander": "^10.0.0",
    "cosmiconfig": "^8.1.3",
    "execa": "^7.0.0",
    "fast-glob": "^3.3.2",
    "fs-extra": "^11.2.0",
    "node-fetch": "^3.3.0",
    "ora": "^6.1.2",
    "prompts": "^2.4.2",
    "qrcode-terminal": "^0.12.0",
    "zod": "^3.20.2"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.1",
    "@types/prompts": "^2.4.2",
    "mermaid": "^11.14.0",
    "prettier": "^3.0.0",
    "rimraf": "^4.1.3",
    "tsup": "^6.6.3",
    "type-fest": "^3.8.0",
    "typescript": "^4.9.3",
    "vite-tsconfig-paths": "^4.3.1",
    "vitepress": "^1.6.4",
    "vitepress-plugin-mermaid": "^2.0.17",
    "vitest": "^1.2.2"
  },
  "engines": {
    "node": ">=18"
  }
}
